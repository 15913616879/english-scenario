          "id": "setting-alarm",
          "title": "Setting the Alarm",
          "title_cn": "设定闹钟",
          "difficulty": "A2",
          "characters": ["Star", "Alex"],
          "status": "ready",
          "lines": [
            {"speaker": "Star", "text": "Hey Alex, can you help me set the alarm? My phone's dead.", "text_cn": "嘿Alex，能帮我设下闹钟吗？我手机没电了。"},
            {"speaker": "Alex", "text": "Sure. What time?", "text_cn": "好的，几点？"},
            {"speaker": "Star", "text": "Six thirty. Got an early meeting tomorrow.", "text_cn": "六点半。明天有个早会。"},
            {"speaker": "Alex", "text": "Done. Want me to set another one at six forty too?", "text_cn": "好了。要不要再设一个六点四十的？"},
            {"speaker": "Star", "text": "Yeah, good call. I always sleep through the first one.", "text_cn": "好主意，我总是睡过头错过第一个闹钟。"},
            {"speaker": "Alex", "text": "Same here. Two alarms is the only way.", "text_cn": "我也是。两个闹钟是唯一办法。"},
            {"speaker": "Star", "text": "Haha, exactly. Thanks, man. Good night.", "text_cn": "哈哈，没错。谢啦兄弟，晚安。"},
            {"speaker": "Alex", "text": "Night. Don't forget to charge your phone.", "text_cn": "晚安。别忘了给手机充电。"}
          ],
          "blanks": [
            {"speaker": "Star", "text": "Hey Alex, can you help me set the ___? My phone's dead.", "answer": "alarm"},
